# ========================================
# CONFIGURAÇÃO DO BANCO DE DADOS (SUPABASE)
# ========================================

# Host do banco Supabase (Session Pooler - IPv4)
# A conexão direta "db.<project_ref>.supabase.co" só responde em IPv6 por padrão,
# o que falha na maioria das redes domésticas/Windows. Use o Session Pooler:
# Project Settings > Database > Connection Pooling > Session mode
DB_HOST=aws-1-sa-east-1.pooler.supabase.com

# Porta do Session Pooler (modo session, compatível com prepared statements do Hibernate)
DB_PORT=5432

# Nome do banco (default no Supabase é 'postgres')
DB_NAME=postgres

# Usuário do pooler: postgres.<project_ref> (não é só "postgres")
DB_USER=postgres.seu_project_ref_aqui

# Senha do seu banco Supabase
# ⚠️ SUBSTITUA PELA SUA SENHA REAL
DB_PASSWORD=sua_senha_supabase_aqui

# ========================================
# CONFIGURAÇÕES DO SPRING BOOT
# ========================================

# Modo de DDL (validate = não altera schema, apenas valida)
SPRING_JPA_HIBERNATE_DDL_AUTO=validate

# Mostrar SQL executado no log (false para production)
SPRING_JPA_SHOW_SQL=false

# ========================================
# SERVIDOR
# ========================================

# Porta da aplicação
SERVER_PORT=8080

# ========================================
# LOGGING
# ========================================

# Nível de log da aplicação
LOGGING_LEVEL_ROOT=INFO
LOGGING_LEVEL_COM_TERRARIA=DEBUG
LOGGING_LEVEL_ORG_SPRINGFRAMEWORK_WEB=DEBUG
LOGGING_LEVEL_ORG_HIBERNATE_SQL=DEBUG

# ========================================
# TOKENS SUPABASE (OPCIONAL)
# ========================================

# Se precisar usar APIs do Supabase no futuro
# SUPABASE_ANON_KEY=sua_chave_anon_aqui
# SUPABASE_SERVICE_KEY=sua_chave_service_role_aqui
